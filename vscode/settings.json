{
    "ansible.lightspeed.enabled": false,
    "ansible.lightspeed.suggestions.enabled": false,
    "breadcrumbs.enabled": false,
    "chat.viewSessions.orientation": "stacked",
    "cSpell.userWords": [
        "Brauns",
        "excalidraw",
        "gravemind",
        "Intune",
        "shellcheck"
    ],
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "modifications",
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [
        {
            "column": 80,
            "color": "#808080"
        },
        {
            "column": 120,
            "color": "#d7a65f80"
        },
        {
            "column": 160,
            "color": "#ff555599"
        }
    ],
    "editor.stickyScroll.enabled": true,
    "excalidraw.theme": "dark",
    "files.associations": {
        "**/defaults/*.yaml": "ansible",
        "**/defaults/*.yml": "ansible",
        "**/group_vars/*.yaml": "ansible",
        "**/group_vars/*.yml": "ansible",
        "**/handlers/*.yaml": "ansible",
        "**/handlers/*.yml": "ansible",
        "**/hostvars/*.yaml": "ansible",
        "**/hostvars/*.yml": "ansible",
        "**/meta/*.yaml": "ansible",
        "**/meta/*.yml": "ansible",
        "**/playbooks/*.yaml": "ansible",
        "**/playbooks/*.yml": "ansible",
        "**/tasks/*.yaml": "ansible",
        "**/tasks/*.yml": "ansible",
        "**/vars/*.yaml": "ansible",
        "**/vars/*.yml": "ansible",
        "bash_*": "shellscript",
        "bashrc": "shellscript"
    },
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.postCommitCommand": "sync",
    "git.replaceTagsWhenPull": true,
    "notebook.lineNumbers": "on",
    "redhat.telemetry.enabled": false,
    "telemetry.telemetryLevel": "off",
    "terminal.integrated.env.linux": {
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
    },
    "terminal.integrated.scrollback": 10000,
    "workbench.editor.empty.hint": "hidden",
    "yaml.customTags": [
        "!secret scalar"
    ],
    "yaml.format.printWidth": 160,
    "[ansible]": {
        "editor.defaultFormatter": "redhat.ansible",
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false
    },
    "[markdown]": {
        "files.trimTrailingWhitespace": false
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false
    }
}
