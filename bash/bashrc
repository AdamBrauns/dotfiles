# ------------------------------------------------------------------------------
# File: .bashrc
# Info: bashrc for non-login interactive shells
# Author: Adam Brauns (@AdamBrauns)
# shellcheck shell=bash
# ------------------------------------------------------------------------------

# Set brew shell environment if homebrew is installed
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Everything below is interactive-only
case $- in
  *i*) ;;
  *) return ;;
esac

# Shell options
shopt -s histappend   # append to history, don't overwrite
shopt -s checkwinsize # update LINES/COLUMNS after each command
shopt -s globstar     # ** matches files recursively

# Initialize starship if available
if command -v starship &> /dev/null; then
  eval "$(starship init bash)"
fi

# Source global definitions
if [[ -f /etc/bashrc ]]; then
  . /etc/bashrc
fi

# Source environment
if [[ -f ~/.bash_env ]]; then
  . ~/.bash_env
fi

# Source secret environment variables
if [[ -f ~/.bash_env_secret ]]; then
  . ~/.bash_env_secret
fi

# Enable bash completion (load the framework before anything that registers completions)
if [[ -s $HOMEBREW_PREFIX/etc/profile.d/bash_completion.sh ]]; then
  . "$HOMEBREW_PREFIX/etc/profile.d/bash_completion.sh"
fi

# Source aliases (kubectl completion here depends on the framework above)
if [[ -f ~/.bash_aliases ]]; then
  . ~/.bash_aliases
fi

# Source functions
if [[ -f ~/.bash_functions ]]; then
  . ~/.bash_functions
fi

# Initialize fzf key bindings and fuzzy completion
if command -v fzf &> /dev/null; then
  eval "$(fzf --bash)"
fi

# Source fzf-git if available
if [[ -f ~/.scripts/fzf-git.sh ]]; then
  . ~/.scripts/fzf-git.sh
fi
