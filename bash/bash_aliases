# ------------------------------------------------------------------------------
# File: .bash_aliases
# Info: User defined bash aliases
# Author: Adam Brauns (@AdamBrauns)
# shellcheck shell=bash
# ------------------------------------------------------------------------------

# General
alias ..='cd ..'
alias ll='ls -l'
alias la='ll -a'
alias grep='grep --color'
alias erep='egrep --color=auto'
alias now='date +"%T"'
alias skurt='exit'
alias tm='tmux'
alias yeet='rm'

# Rename files by replacing spaces/underscores with dashes and converting to lowercase
alias rndir='rename "s/[ _]/-/g; y/A-Z/a-z/" * -f'

# Format shell scripts with consistent style (2 spaces, indent case/esac, binary operators on separate lines)
# https://google.github.io/styleguide/shellguide.html
alias shfmt='shfmt -w -i 2 -ci -bn'

# Cross-platform port listing
if netstat -tulanp &>/dev/null 2>&1; then
  alias ports='netstat -tulanp'
else
  alias ports='netstat -an | grep LISTEN'
fi

# Detect OS for ls colors
if ls --color=auto &>/dev/null 2>&1; then
  alias ls='ls --color=auto'
else
  alias ls='ls -G'
fi

# Change Directory
alias cddot='cd ${DIR_GIT_DOT}'
alias cdgit='cd ${DIR_GIT}'
alias cdmono='cd ${DIR_GIT_MONO}'
alias cdpers='cd ${DIR_GIT_PERSONAL}'
alias cdwork='cd ${DIR_GIT_WORK}'

# Ansible
alias ansdecrypt='ansible-vault decrypt'
alias ansencrypt='ansible-vault encrypt'

# Brew
if command -v brew &> /dev/null; then
  alias brewup='brew update && brew upgrade'
  alias brewall='brew update && brew upgrade --greedy'
  alias brewdump='brew bundle dump -f'
  alias brewclean='brew autoremove && brew cleanup'
fi

# Claude
if command -v claude &> /dev/null; then
  alias cc='claude'
fi

# Codex
if command -v codex &> /dev/null; then
  alias cx='codex'
fi

# Container
if command -v container &> /dev/null; then
  alias cnt='container'
fi

# Colima
if command -v colima &> /dev/null; then
  alias cod='colima start --kubernetes=false'
  alias cok='colima start --kubernetes'
  alias cos='colima stop'
  alias costatus='colima status'
fi

# Docker
if command -v docker &> /dev/null; then
  alias dk='docker'
  alias dkc='docker compose'
  alias dkps='docker ps'
  alias dkpa='docker ps -a'
  alias dki='docker images'
  alias dkex='docker exec -it'
  alias dklog='docker logs -f'
  alias dkrm='docker rm'
  alias dkrmi='docker rmi'
  alias dkclean='docker system prune -a'
  alias dkcleanf='docker system prune -af'
  alias dkvolclean='docker volume prune'
  alias dknetclean='docker network prune'
  alias dkstartall='docker ps -aq -f status=exited | xargs -r docker start'
  alias dkstopall='docker ps -q | xargs -r docker stop'
  alias dkrmall='docker ps -aq -f status=exited -f status=created | xargs -r docker rm'
  alias dknuke='docker ps -aq | xargs -r docker rm -f'
fi

# Kubernetes
if command -v kubectl &> /dev/null; then
  alias k='kubectl'
fi

# UV (Python tools)
if command -v uv &> /dev/null; then
  alias uvup='uv tool upgrade --all'
  alias uvinstall='grep -vE "^\s*(#|$)" ~/.config/uv/tools.txt | xargs -I{} uv tool install {}'
  alias uvall='uvinstall && uvup'
  alias uvdump='uv tool list 2>/dev/null | grep -v "^-" | awk "{print \$1}" | sort > ~/.config/uv/tools.txt'
  alias uvclean='uv cache clean'
fi

# SSH
alias sshpi='ssh ${HOST_PI}'
alias sshprox='ssh ${HOST_PROX}'

# Git
# Interactive branch switcher with fzf (shows recent branches, preview diffs)
alias gbs="git branch --sort=-committerdate --color=always \
  | fzf --border --reverse --ansi \
       --header \"Recent branches (↑ newest)\" \
       --preview \"git diff --color=always {1} | head -500\" \
       --preview-window right,70% \
  | sed 's/.* //' \
  | xargs git checkout"

# Stage selected changed/untracked files (multi-select with TAB)
alias ga="git ls-files -m -o --exclude-standard \
  | fzf -m --preview 'git diff --color=always {}' \
       --preview-window right,70% \
       --header 'Stage files (multi-select with TAB)' \
  | xargs git add"

# Interactive interactive add --patch (great for partial staging)
alias gap="git ls-files -m --exclude-standard \
  | fzf -m --preview 'git diff --color=always {}' \
       --preview-window right,70% \
       --header 'Partial staging (multi-select with TAB)' \
  | xargs -o git add -p"

# Unstage selected staged files
alias gus="git diff --name-only --cached \
  | fzf -m --preview 'git diff --color=always --cached {}' \
       --preview-window right,70% \
       --header 'Unstage files (multi-select with TAB)' \
  | xargs git restore --staged"

# Review staged changes and commit
alias gc="git diff --name-only --cached \
  | fzf --preview 'git diff --color=always --cached {}' \
       --preview-window right,70% \
       --header 'Review staged changes (Enter to commit, Esc to cancel)' \
  > /dev/null && git commit"

# Interactive status viewer with file diffs
# shellcheck disable=SC2142,SC2154
alias gs="git status --short \
  | fzf --ansi --preview \
       'f=\$(echo {} | awk \"{print \\\$2}\"); \
        git diff --color=always \$f 2>/dev/null || git diff --color=always --cached \$f 2>/dev/null || cat \$f' \
       --preview-window right,70% \
       --header 'Git status (view changes)' \
  > /dev/null"

# Discard changes in selected files (restore to last commit)
alias gr="git ls-files -m \
  | fzf -m --preview 'git diff --color=always {}' \
       --preview-window right,70% \
       --header 'Discard changes (multi-select with TAB)' \
  | xargs git restore"

# Browse commit history with diffs
# shellcheck disable=SC2142
alias gl="git log --oneline --color=always \
  | fzf --ansi --preview \
       'git show --color=always \$(echo {} | awk \"{print \\\$1}\")' \
       --preview-window right,70% \
       --header 'Commit history' \
  > /dev/null"
